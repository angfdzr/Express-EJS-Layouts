<!--begin::Sidebar-->
<aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
    <!--begin::Sidebar Brand-->
    <div class="sidebar-brand">
        <!--begin::Brand Link-->
        <a href="./index.html" class="brand-link">
            <!--begin::Brand Image-->
            <img src="/admin/assets/img/AdminLTELogo.png" alt="AdminLTE Logo" class="brand-image opacity-75 shadow" />
            <!--end::Brand Image-->
            <!--begin::Brand Text-->
            <span class="brand-text fw-light">AdminLTE 4</span>
            <!--end::Brand Text-->
        </a>
        <!--end::Brand Link-->
    </div>
    <!--end::Sidebar Brand-->
    <!--begin::Sidebar Wrapper-->
    <div class="sidebar-wrapper">
        <nav class="mt-2">
            <!--begin::Sidebar Menu-->
            <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="navigation"
                aria-label="Main navigation" data-accordion="false" id="navigation">
                <% (sidebar || []).forEach(function(item){ const hasActive=(activePage===item.url) ||
                    ((item.submenus||[]).some(sm=> sm.url === activePage));
                    %>
                    <% if (item.is_dropdown) { %>
                        <li class="nav-item <%= hasActive ? 'menu-open' : '' %>">
                            <a href="<%= item.url || '#' %>" class="nav-link <%= hasActive ? 'active' : '' %>">
                                <i class="nav-icon <%= item.icon %>"></i>
                                <p>
                                    <%= item.title %>
                                        <i class="nav-arrow bi bi-chevron-right"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">
                                <% (item.submenus || []).forEach(function(sm){ %>
                                    <li class="nav-item">
                                        <a href="<%= sm.url %>"
                                            class="nav-link <%= (activePage === sm.url) ? 'active' : '' %>">
                                            <i class="nav-icon bi bi-circle"></i>
                                            <p>
                                                <%= sm.title %>
                                            </p>
                                        </a>
                                    </li>
                                    <% }) %>
                            </ul>
                        </li>
                        <% } else { %>
                            <li class="nav-item">
                                <a href="<%= item.url %>"
                                    class="nav-link <%= (activePage === item.url) ? 'active' : '' %>">
                                    <i class="nav-icon <%= item.icon %>"></i>
                                    <p>
                                        <%= item.title %>
                                    </p>
                                </a>
                            </li>
                            <% } %>
                                <% }) %>
            </ul>
            <!--end::Sidebar Menu-->
        </nav>
    </div>
    <!--end::Sidebar Wrapper-->
</aside>
<!--end::Sidebar-->