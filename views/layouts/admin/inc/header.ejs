                    <!--end::User Image-->
                    <!--begin::Menu Footer-->
                    <form action="/logout" method="post">
                        <li class="user-footer">
                            <button class="btn btn-default btn-flat float-end" id="btn-logout">Sign out</button>
                        </li>
